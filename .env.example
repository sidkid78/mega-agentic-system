# Copy to .env and fill in. docker compose reads this file automatically.
#
# Bring-your-own-key: users enter their Gemini key in the app UI, so NONE of
# these are required to run the stack. They only tweak local/deploy behaviour.

# Optional. A local-dev fallback key for the few endpoints not yet BYOK-wired
# (deeper RAG / scout). Leave blank for pure BYOK — the UI supplies the key.
GEMINI_API_KEY=

# Optional. Host port for the frontend UI. Change if 3000 is taken locally.
FRONTEND_PORT=3000

# Optional. Where the browser reaches the backend API. Baked into the frontend
# at build time, so rebuild the frontend after changing it.
#   - local docker compose:  http://localhost:8010
#   - deployed:              https://your-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8010
